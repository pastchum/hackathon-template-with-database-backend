# ──────────────────────────────────────────────────────────────────────────────
# Next.js — copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Supabase project URL (used server-side only for session management)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon key (used server-side only for session management)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# FastAPI backend URL (Next.js proxies data/auth requests here)
BACKEND_URL=http://localhost:8000
